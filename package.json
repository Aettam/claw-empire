{
  "name": "climpire",
  "version": "2.0.4",
  "description": "Claw-Empire - AI Agent Company Simulation. Command your CLI agent empire from the CEO desk.",
  "type": "module",
  "scripts": {
    "migrate:v1.0.5": "node scripts/auto-apply-v1.0.5.mjs",
    "migrate:custom-skills": "node scripts/migrate-custom-skills-canonical.mjs",
    "predev": "node scripts/auto-apply-v1.0.5.mjs",
    "predev:local": "node scripts/auto-apply-v1.0.5.mjs",
    "predev:e2e": "node scripts/auto-apply-v1.0.5.mjs",
    "predev:tailscale": "node scripts/auto-apply-v1.0.5.mjs",
    "prestart": "node scripts/auto-apply-v1.0.5.mjs && node scripts/ensure-remotion-runtime.mjs",
    "prestart:tailscale": "node scripts/auto-apply-v1.0.5.mjs && node scripts/ensure-remotion-runtime.mjs",
    "dev": "concurrently -n web,api -c cyan,magenta \"cross-env VITE_DEV=1 vite --host 0.0.0.0 --port 8800\" \"cross-env VITE_DEV=1 HOST=0.0.0.0 nodemon --watch server --ext ts --exec tsx server/index.ts\"",
    "dev:local": "concurrently -n web,api -c cyan,magenta \"cross-env VITE_DEV=1 vite --host 127.0.0.1 --port 8800\" \"cross-env VITE_DEV=1 HOST=127.0.0.1 nodemon --watch server --ext ts --exec tsx server/index.ts\"",
    "dev:e2e": "node scripts/prepare-e2e-runtime.mjs && cross-env VITE_DEV=1 HOST=127.0.0.1 DB_PATH=.tmp/e2e-runtime/claw-empire.e2e.sqlite LOGS_DIR=.tmp/e2e-runtime/logs INBOX_WEBHOOK_SECRET=claw-e2e-inbox-secret concurrently -n web,api -c cyan,magenta \"vite --host 127.0.0.1 --port 8810\" \"nodemon --watch server --ext ts --exec tsx server/index.ts\"",
    "dev:tailscale": "concurrently -n web,api -c cyan,magenta \"cross-env VITE_DEV=1 vite --host 0.0.0.0 --port 8800\" \"cross-env VITE_DEV=1 HOST=0.0.0.0 nodemon --watch server --ext ts --exec tsx server/index.ts\"",
    "start": "tsx server/index.ts",
    "start:tailscale": "cross-env HOST=0.0.0.0 tsx server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "setup": "node scripts/setup.mjs",
    "arch:map": "node scripts/generate-architecture-report.mjs",
    "preflight:public": "bash scripts/preflight-public.sh",
    "audit:verify": "node scripts/verify-security-audit-log.mjs",
    "test:comm:llm": "node scripts/qa/llm-comm-test.mjs",
    "test:comm:oauth": "node scripts/qa/oauth-comm-test.mjs",
    "test:comm:api": "node scripts/qa/api-comm-test.mjs",
    "test:comm:suite": "node scripts/qa/run-comm-suite.mjs",
    "test:comm-status": "node scripts/test-comm-status.mjs",
    "test:qa:office:smoke": "node scripts/qa/office-console-smoke.mjs",
    "test:qa:office:perf": "node scripts/qa/office-performance-baseline.mjs",
    "test:qa:office:resolutions": "node scripts/qa/office-resolution-compare.mjs",
    "test:qa:office:management": "node scripts/qa/office-management-requirements.mjs",
    "test:qa:office:theme": "node scripts/qa/office-theme-requirements.mjs",
    "test:qa:project-path": "node scripts/qa/project-path-api-smoke.mjs",
    "test:web": "vitest --config vitest.config.ts",
    "test:api": "vitest --config server/vitest.config.ts",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test": "pnpm run test:web && pnpm run test:api",
    "test:ci": "pnpm run test:web --coverage && pnpm run test:api --coverage && pnpm run openapi:check && pnpm run test:e2e",
    "lint": "eslint src server",
    "lint:fix": "eslint src server --fix",
    "lint:staged": "lint-staged",
    "openapi:sync": "node scripts/openapi-contract.mjs --write",
    "openapi:check": "node scripts/openapi-contract.mjs --check",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,yml,yaml,css,scss,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,yml,yaml,css,scss,html}\"",
    "sprites:optimize": "node scripts/optimize-sprites.mjs"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.482",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^1.21.0",
    "pixi.js": "^8.19.0",
    "pptxgenjs": "^3.12.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "remotion": "^4.0.482",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.14.6",
    "nodemon": "^3.1.14",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.61.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "sharp": "^0.35.2",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,yml,yaml,css,scss,html}": "prettier --write",
    "{src/api,server/config}/**/*.ts": "eslint --fix --max-warnings=0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "shell-quote": ">=1.8.4",
      "minimatch": ">=9.0.5",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "fast-uri": ">=3.1.2",
      "form-data": ">=4.0.6",
      "qs": ">=6.15.2",
      "rollup": ">=4.59.0",
      "esbuild": ">=0.28.1",
      "js-yaml": ">=4.2.0",
      "yaml": ">=2.8.3"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
