# Claw-Empire — Docker SECRETS template
# ---------------------------------------------------------------------------
# Copy this file to `.env.docker.private` and fill in real values, then keep
# the copy local only (it is gitignored — secrets must never be committed):
#
#   cp .env.docker.private.example .env.docker.private
#   chmod 600 .env.docker.private
#
# docker-compose.yml loads BOTH files via env_file:
#   - .env.docker          (non-secret config, committed)
#   - .env.docker.private  (secrets, gitignored — generated from this template)
#
# Generate a 32-byte hex secret for any "__CHANGE_ME__" below with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------------------

# ── Required ──────────────────────────────────────────────────────
# Encrypts OAuth + messenger channel tokens stored in SQLite (AES-256-GCM).
# The container will not be able to read previously-encrypted tokens if this
# value changes, so generate it once and keep it stable.
OAUTH_ENCRYPTION_SECRET="__CHANGE_ME__"

# Required when HOST != 127.0.0.1 (the Docker image sets HOST=0.0.0.0, so a
# token is required for any non-loopback access). Remote browser clients send
# this at runtime via the API_AUTH_TOKEN header; it is not baked into the
# frontend build.
API_AUTH_TOKEN="__CHANGE_ME__"

# ── Optional ──────────────────────────────────────────────────────
# Required only if you use the /api/inbox webhook endpoint. Senders pass this
# value in the `x-inbox-secret` request header.
# INBOX_WEBHOOK_SECRET="__CHANGE_ME__"

# Legacy fallback for OAUTH_ENCRYPTION_SECRET (only read when the primary
# secret above is unset). Prefer OAUTH_ENCRYPTION_SECRET for new deployments.
# SESSION_SECRET="__CHANGE_ME__"

# ── Optional model-provider secrets ───────────────────────────────
# Only needed for direct-API agent paths (most CLI agent paths do not use
# these). Uncomment and fill the ones you actually use.
# OPENAI_API_KEY="__CHANGE_ME__"
# OAUTH_GITHUB_CLIENT_SECRET="__CHANGE_ME__"
# OAUTH_GOOGLE_CLIENT_SECRET="__CHANGE_ME__"
# GEMINI_OAUTH_CLIENT_SECRET="__CHANGE_ME__"

# Claude Code via a compatible Anthropic-style endpoint (optional).
# ANTHROPIC_BASE_URL="https://api.example.com/anthropic"
# ANTHROPIC_API_KEY="__CHANGE_ME__"
