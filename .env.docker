# Claw-Empire — Docker container environment
# This file is loaded by docker-compose.yml (env_file).
# It contains NON-SECRET configuration only and is safe to commit.
# Secrets go in .env.docker.private (gitignored).

# ── Server ────────────────────────────────────────────────────────
# Listen on all interfaces inside the container so Docker port
# mapping works.  The host-side port is set in docker-compose.yml.
PORT=8790
HOST=0.0.0.0

# ── API auth ──────────────────────────────────────────────────────
# Required when HOST != 127.0.0.1.  The actual token value lives
# in .env.docker.private — this line just documents the requirement.
# API_AUTH_TOKEN is set in .env.docker.private

# ── Database & logs ───────────────────────────────────────────────
# docker-compose.yml overrides these via the `environment:` block
# (DB_PATH=/app/data/claw-empire.sqlite, LOGS_DIR=/app/data/logs).
# Uncomment only if you need to change the container-internal paths.
# DB_PATH=/app/data/claw-empire.sqlite
# LOGS_DIR=/app/data/logs

# ── OAuth callback base URL ──────────────────────────────────────
# Set this to the public URL where the container is reachable so
# OAuth redirect URIs resolve correctly.
# OAUTH_BASE_URL="https://claw.example.com"

# ── CORS ──────────────────────────────────────────────────────────
# Extra trusted origins / suffixes for cross-origin requests.
# ALLOWED_ORIGINS="https://claw.example.com"
# ALLOWED_ORIGIN_SUFFIXES=".ts.net,.example.com"

# ── OAuth providers ───────────────────────────────────────────────
# All OAuth providers have built-in fallbacks and are optional.
# Uncomment and fill only the ones you actually use.

# GitHub OAuth (Settings -> Developer settings -> OAuth Apps)
# OAUTH_GITHUB_CLIENT_ID="__CHANGE_ME__"
# OAUTH_GITHUB_CLIENT_SECRET="__CHANGE_ME__"

# Google OAuth (Google Cloud Console -> OAuth consent screen)
# OAUTH_GOOGLE_CLIENT_ID="__CHANGE_ME__"
# OAUTH_GOOGLE_CLIENT_SECRET="__CHANGE_ME__"

# Gemini OAuth (explicit credentials; falls back to Google OAuth)
# GEMINI_OAUTH_CLIENT_ID="__CHANGE_ME__"
# GEMINI_OAUTH_CLIENT_SECRET="__CHANGE_ME__"

# ── Model provider API keys ──────────────────────────────────────
# Only needed for direct-API agent paths.  Secrets belong in
# .env.docker.private; these lines are here for documentation.
# OPENAI_API_KEY is set in .env.docker.private (if needed)
# GOOGLE_CLOUD_PROJECT="__CHANGE_ME__"
# GOOGLE_CLOUD_PROJECT_ID="__CHANGE_ME__"

# ── Meeting prompt budget tuning ─────────────────────────────────
# Defaults are sane; uncomment to override.
# MEETING_PROMPT_TASK_CONTEXT_MAX_CHARS=1200
# MEETING_TRANSCRIPT_MAX_TURNS=20
# MEETING_TRANSCRIPT_LINE_MAX_CHARS=180
# MEETING_TRANSCRIPT_TOTAL_MAX_CHARS=2400
# REVIEW_MEETING_ONESHOT_TIMEOUT_MS=65000
